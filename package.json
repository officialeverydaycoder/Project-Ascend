{
  "name": "Project-Ascend",
  "version": "1.0.0",
  "description": "JEE Aspirant's Perfect Choice.",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/officialeverydaycoder/Project-Ascend.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 -p always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.project.ascend",
    "productName": "Project Ascend",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "officialeverydaycoder",
        "repo": "Project-Ascend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ascend"
    },
    "files": [
      "electron/**/*",
      "src/**/*"
    ]
  }
}